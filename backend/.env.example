# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL for production, omit for SQLite in dev)
DATABASE_URL=postgres://user:password@localhost:5432/guestflow

# Redis (optional in dev)
REDIS_URL=redis://localhost:6379/0

# CORS (production only — comma-separated origins)
CORS_ALLOWED_ORIGINS=https://guestflow.ge,https://www.guestflow.ge

# Field-level encryption key for PII (passport numbers, API credentials)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Celery (defaults to REDIS_URL)
# CELERY_TASK_ALWAYS_EAGER=True
